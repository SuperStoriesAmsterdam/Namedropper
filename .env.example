# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://namedropper:password@localhost:5432/namedropper
DB_PASSWORD=changeme                # Used by docker-compose for the PostgreSQL container

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── File storage (Cloudflare R2) ─────────────────────────────
R2_ENDPOINT_URL=                    # https://[account-id].r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=namedropper
R2_PUBLIC_URL=https://media.superstories.com

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@superstories.nl

# ── Auth ─────────────────────────────────────────────────────
APP_SECRET_KEY=                     # Secret key for signing magic link tokens (generate a random 64-char string)
APP_BASE_URL=https://namedropper.superstories.com

# ── ElevenLabs ───────────────────────────────────────────────
ELEVENLABS_API_KEY=                 # API key from elevenlabs.io dashboard
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Product ──────────────────────────────────────────────────
PRODUCT_ID=namedropper
APP_VERSION=0.1.0
